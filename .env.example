# Server
PORT=8443
NODE_ENV=production

# TLS (same Let's Encrypt certs as vapipbx)
SSL_KEY_PATH=/etc/letsencrypt/live/pbx.ckstudios.work/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/pbx.ckstudios.work/fullchain.pem

# Auth (bearer token for dashboard requests)
CONFIG_SERVICE_TOKEN=<generate-a-strong-random-token>

# FreePBX REST API (OAuth2)
FREEPBX_CLIENT_ID=<oauth2-client-id>
FREEPBX_CLIENT_SECRET=<oauth2-client-secret>

# MariaDB (FreePBX asterisk database)
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=freepbxuser
MARIADB_PASS=<password>
MARIADB_DB=asterisk
